<div class="page-header">
    <a href="/panel/nodes/<%= node._id %>" class="btn btn-back">← Назад к ноде</a>
</div>

<% if (message) { %>
<div class="alert alert-success"><%= message %></div>
<% } %>
<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<style>
/* ===== FLOW DIAGRAM ===== */
.ob-flow {
    display: flex; align-items: center; gap: 8px;
    background: var(--bg-secondary); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 12px 16px;
    margin-bottom: 20px; font-size: 13px; flex-wrap: wrap;
}
.ob-flow-step {
    display: flex; align-items: center; gap: 6px;
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 6px; padding: 6px 12px; white-space: nowrap;
}
.ob-flow-arrow { color: var(--text-muted); font-size: 16px; }

/* ===== PRESETS ===== */
.presets-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-top: 12px; }
.preset-card {
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 14px; cursor: pointer; transition: all 0.15s;
    background: var(--bg-secondary);
}
.preset-card:hover { border-color: var(--accent); background: var(--accent-bg, rgba(59,130,246,0.05)); }
.preset-card.active { border-color: var(--accent); background: var(--accent-bg, rgba(59,130,246,0.08)); }
.preset-icon { font-size: 22px; margin-bottom: 6px; }
.preset-title { font-weight: 600; font-size: 13px; margin-bottom: 3px; }
.preset-desc { font-size: 12px; color: var(--text-muted); line-height: 1.4; }

/* ===== OUTBOUND CARDS ===== */
.ob-cards { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
.ob-card {
    display: flex; align-items: center; gap: 10px;
    background: var(--bg-secondary); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 10px 14px;
    font-size: 13px; min-width: 160px;
}
.ob-card-icon { font-size: 18px; flex-shrink: 0; }
.ob-card-info { flex: 1; min-width: 0; }
.ob-card-name { font-weight: 600; }
.ob-card-detail { font-size: 11px; color: var(--text-muted); margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ob-card-del {
    background: none; border: none; color: var(--text-muted);
    cursor: pointer; padding: 2px 4px; border-radius: 4px;
    font-size: 14px; line-height: 1; flex-shrink: 0;
    transition: all 0.15s;
}
.ob-card-del:hover { color: #ff6b6b; background: rgba(255,107,107,0.1); }
.ob-type-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; white-space: nowrap;
}
.ob-type-direct  { background: rgba(81,207,102,0.15); color: #51cf66; }
.ob-type-block   { background: rgba(255,107,107,0.15); color: #ff6b6b; }
.ob-type-socks5  { background: rgba(99,102,241,0.15);  color: #818cf8; }
.ob-type-http    { background: rgba(251,191,36,0.15);  color: #fbbf24; }

/* ===== ADD FORM ===== */
.add-ob-row {
    display: flex; gap: 8px; align-items: flex-end; flex-wrap: wrap;
    padding: 14px; background: var(--bg-secondary); border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
}
.add-ob-row .form-group { margin: 0; }
.add-ob-row .fg-name { flex: 1.5; min-width: 130px; }
.add-ob-row .fg-type { flex: 0 0 110px; }
.add-ob-row .fg-addr { flex: 2; min-width: 160px; }
.add-ob-row .fg-cred { flex: 1; min-width: 100px; }
.add-ob-row .fg-btn  { flex: 0 0 auto; }

/* ===== ACL CHIPS ===== */
.acl-ob-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
.acl-ob-chip {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;
    cursor: pointer; border: none; transition: all 0.15s; font-family: monospace;
}
.acl-ob-chip:hover { filter: brightness(1.2); transform: scale(1.04); }

/* ===== ACL EDITOR ===== */
.acl-editor {
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px;
    width: 100%;
    resize: vertical;
    min-height: 130px;
    line-height: 1.7;
}
.acl-editor:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-glow); }
.acl-hint-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.acl-tag {
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 4px; padding: 2px 8px; font-size: 12px;
    font-family: monospace; cursor: pointer; color: var(--text-muted);
    transition: all 0.15s;
}
.acl-tag:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

/* ===== YAML PREVIEW ===== */
.preview-toggle {
    display: flex; align-items: center; gap: 8px; cursor: pointer;
    font-size: 13px; color: var(--text-muted); padding: 8px 0;
    border: none; background: none; width: 100%;
    border-top: 1px solid var(--border); margin-top: 8px;
}
.preview-toggle:hover { color: var(--text-primary); }
.preview-yaml {
    background: #1a1a2e; color: #a9dc76; padding: 14px;
    border-radius: var(--radius-sm); font-family: monospace; font-size: 12px;
    line-height: 1.6; white-space: pre-wrap; word-break: break-all;
    max-height: 280px; overflow-y: auto; margin-top: 8px;
}
.empty-state { text-align: center; padding: 24px 0; color: var(--text-muted); font-size: 13px; }

@media (max-width: 600px) {
    .add-ob-row { flex-direction: column; }
    .add-ob-row .fg-name, .add-ob-row .fg-addr, .add-ob-row .fg-cred { flex: 1 1 100%; }
    .presets-grid { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="card">
    <div class="card-header">
        <h2>Маршрутизация трафика — <%= node.name %></h2>
    </div>
    <div class="card-body">

        <!-- FLOW DIAGRAM -->
        <div class="ob-flow">
            <div class="ob-flow-step">👤 Клиент подключается</div>
            <span class="ob-flow-arrow">→</span>
            <div class="ob-flow-step">📋 ACL-правила <small style="color:var(--text-muted)">(кому куда?)</small></div>
            <span class="ob-flow-arrow">→</span>
            <div class="ob-flow-step">↗ Outbound <small style="color:var(--text-muted)">(точка выхода)</small></div>
            <span class="ob-flow-arrow">→</span>
            <div class="ob-flow-step">🌐 Интернет</div>
        </div>

        <form method="POST" action="/panel/nodes/<%= node._id %>/outbounds" id="outboundsForm">

            <!-- ===== PRESETS ===== -->
            <div class="form-section">
                <h3>Готовые сценарии <small style="font-weight:400; color:var(--text-muted); font-size:12px;">— нажмите чтобы применить</small></h3>
                <div class="presets-grid">
                    <div class="preset-card" onclick="applyPreset('block-ads')">
                        <div class="preset-icon">🚫</div>
                        <div class="preset-title">Блокировать рекламу</div>
                        <div class="preset-desc">Блокирует популярные рекламные домены</div>
                    </div>
                    <div class="preset-card" onclick="applyPreset('block-cn')">
                        <div class="preset-icon">🇨🇳</div>
                        <div class="preset-title">Блокировать CN/Private</div>
                        <div class="preset-desc">Запрещает соединения с китайскими и частными IP-адресами</div>
                    </div>
                    <div class="preset-card" onclick="applyPreset('direct-ru')">
                        <div class="preset-icon">🇷🇺</div>
                        <div class="preset-title">Прямой доступ для RU</div>
                        <div class="preset-desc">Российские сайты — напрямую, остальное через VPN</div>
                    </div>
                    <div class="preset-card" onclick="applyPreset('direct-all')">
                        <div class="preset-icon">↗</div>
                        <div class="preset-title">Весь трафик напрямую</div>
                        <div class="preset-desc">Сервер перенаправляет всё без ограничений</div>
                    </div>
                </div>
            </div>

            <!-- ===== OUTBOUND SERVERS ===== -->
            <div class="form-section">
                <h3>Точки выхода (Outbounds)</h3>
                <p class="hint" style="margin-bottom:14px">Задайте именованные маршруты. Затем в правилах ниже укажите, какой трафик через какой маршрут пускать.</p>

                <!-- Cards list -->
                <div class="ob-cards" id="obCards">
                    <!-- populated by JS -->
                </div>
                <div class="empty-state" id="emptyState" style="display:none">
                    Нет точек выхода. По умолчанию весь трафик идёт напрямую.
                </div>

                <!-- Hidden inputs for form submit -->
                <div id="obHiddenInputs"></div>

                <!-- Add form -->
                <div class="add-ob-row" id="addObRow">
                    <div class="form-group fg-name">
                        <label>Название</label>
                        <input type="text" id="newObName" placeholder="ads-block" maxlength="40" onkeydown="if(event.key==='Enter'){event.preventDefault();addOutbound();}">
                    </div>
                    <div class="form-group fg-type">
                        <label>Тип</label>
                        <select id="newObType" onchange="onTypeChange(this.value)">
                            <option value="block">🚫 block</option>
                            <option value="direct">↗ direct</option>
                            <option value="socks5">🔁 socks5</option>
                            <option value="http">🌐 http</option>
                        </select>
                    </div>
                    <div class="form-group fg-addr" id="addrField" style="display:none">
                        <label>Адрес (host:port)</label>
                        <input type="text" id="newObAddr" placeholder="1.2.3.4:1080">
                    </div>
                    <div class="form-group fg-cred" id="userField" style="display:none">
                        <label>Логин</label>
                        <input type="text" id="newObUsername" placeholder="user">
                    </div>
                    <div class="form-group fg-cred" id="passField" style="display:none">
                        <label>Пароль</label>
                        <input type="password" id="newObPassword" placeholder="">
                    </div>
                    <div class="form-group fg-btn">
                        <label>&nbsp;</label>
                        <button type="button" class="btn btn-primary" onclick="addOutbound()">+ Добавить</button>
                    </div>
                </div>
            </div>

            <!-- ===== ACL RULES ===== -->
            <div class="form-section">
                <h3>Правила маршрутизации (ACL)</h3>
                <p class="hint">Одно правило на строку. Формат: <code>имя_выхода(условие)</code>. Правила применяются сверху вниз — первое совпавшее выигрывает.</p>

                <div id="noAclWarning" class="alert alert-warning" style="display:none; margin-bottom:10px; font-size:13px;">
                    ⚠️ Есть прокси-outbound, но нет правил — прокси никогда не будет использоваться. Добавьте правило, например: <code id="aclExampleRule">my-proxy(all)</code>
                </div>

                <!-- Outbound chips — click to insert into ACL -->
                <div id="aclChipsWrap" style="display:none; margin-bottom:10px;">
                    <small style="color:var(--text-muted)">Нажмите на выход, чтобы вставить его в правило:</small>
                    <div class="acl-ob-chips" id="aclObChips"></div>
                </div>

                <textarea name="aclRules" id="aclRulesEditor" class="acl-editor"
                    placeholder="block(suffix:doubleclick.net)&#10;block(geoip:cn)&#10;block(geoip:private)&#10;direct(all)"><%= (node.aclRules || []).join('\n') %></textarea>

                <div style="margin-top: 10px;">
                    <small style="color: var(--text-muted)">Быстрые шаблоны:</small>
                    <div class="acl-hint-tags">
                        <span class="acl-tag" onclick="insertAcl('direct(all)')">direct(all)</span>
                        <span class="acl-tag" onclick="insertAcl('block(geoip:cn)')">block(geoip:cn)</span>
                        <span class="acl-tag" onclick="insertAcl('block(geoip:private)')">block(geoip:private)</span>
                        <span class="acl-tag" onclick="insertAcl('block(geoip:ru)')">block(geoip:ru)</span>
                        <span class="acl-tag" onclick="insertAcl('direct(geoip:ru)')">direct(geoip:ru)</span>
                        <span class="acl-tag" onclick="insertAcl('block(suffix:doubleclick.net)')">block(suffix:doubleclick.net)</span>
                        <span class="acl-tag" onclick="insertAcl('block(suffix:googlesyndication.com)')">block(suffix:googlesyndication.com)</span>
                        <span class="acl-tag" onclick="insertAcl('block(suffix:googleadservices.com)')">block(suffix:googleadservices.com)</span>
                        <span class="acl-tag" onclick="insertAcl('direct(suffix:local)')">direct(suffix:local)</span>
                    </div>
                </div>

                <div class="alert alert-warning" style="margin-top:12px; font-size:12px; padding:8px 12px;">
                    ℹ️ Если задать правила, дефолтные правила сервера (<code>reject(geoip:cn)</code>, <code>reject(geoip:private)</code>) отключатся. При необходимости добавьте их вручную.
                </div>

                <!-- YAML preview — collapsed -->
                <button type="button" class="preview-toggle" onclick="togglePreview()" id="previewToggle">
                    <span id="previewArrow">▶</span> Предпросмотр YAML-конфига
                </button>
                <pre class="preview-yaml" id="yamlPreview" style="display:none"></pre>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                <button type="button" class="btn btn-success" id="btnApply" onclick="saveAndApply()"
                    <%= !node.ssh?.password && !node.ssh?.privateKey ? 'disabled title="Настройте SSH для ноды"' : '' %>>
                    🚀 Сохранить и применить к ноде
                </button>
                <a href="/panel/nodes/<%= node._id %>" class="btn">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
const NODE_ID = '<%= node._id %>';

let pendingOutbounds = <%- JSON.stringify(node.outbounds || []) %>;

const TYPE_META = {
    direct: { icon: '↗', label: 'direct', cls: 'ob-type-direct' },
    block:  { icon: '🚫', label: 'block',  cls: 'ob-type-block'  },
    socks5: { icon: '🔁', label: 'socks5', cls: 'ob-type-socks5' },
    http:   { icon: '🌐', label: 'http',   cls: 'ob-type-http'   },
};

// ===== PRESETS =====
const PRESETS = {
    'block-ads': {
        outbounds: [{ name: 'block', type: 'block', addr: '', username: '', password: '' }],
        acl: [
            'block(suffix:doubleclick.net)',
            'block(suffix:googlesyndication.com)',
            'block(suffix:googleadservices.com)',
            'block(suffix:adnxs.com)',
            'block(suffix:moatads.com)',
            'direct(all)',
        ],
    },
    'block-cn': {
        outbounds: [{ name: 'block', type: 'block', addr: '', username: '', password: '' }],
        acl: ['block(geoip:cn)', 'block(geoip:private)', 'direct(all)'],
    },
    'direct-ru': {
        outbounds: [
            { name: 'direct', type: 'direct', addr: '', username: '', password: '' },
        ],
        acl: ['direct(geoip:ru)', 'direct(all)'],
    },
    'direct-all': {
        outbounds: [{ name: 'direct', type: 'direct', addr: '', username: '', password: '' }],
        acl: ['direct(all)'],
    },
};

function applyPreset(key) {
    const p = PRESETS[key];
    if (!p) return;

    if (pendingOutbounds.length > 0 || document.getElementById('aclRulesEditor').value.trim()) {
        if (!confirm('Это заменит текущие outbounds и правила. Продолжить?')) return;
    }

    pendingOutbounds = p.outbounds.map(o => ({ ...o }));
    document.getElementById('aclRulesEditor').value = p.acl.join('\n');

    renderAll();

    // Highlight preset card briefly
    document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
    event.currentTarget.classList.add('active');
    setTimeout(() => event.currentTarget.classList.remove('active'), 1200);
}

// ===== TYPE CHANGE =====
function onTypeChange(type) {
    const needsAddr = type === 'socks5' || type === 'http';
    ['addrField', 'userField', 'passField'].forEach(id => {
        document.getElementById(id).style.display = needsAddr ? '' : 'none';
    });
}

// ===== ADD OUTBOUND =====
function addOutbound() {
    const name = document.getElementById('newObName').value.trim();
    const type = document.getElementById('newObType').value;
    const addr = document.getElementById('newObAddr').value.trim();
    const username = document.getElementById('newObUsername').value.trim();
    const password = document.getElementById('newObPassword').value.trim();

    if (!name) { document.getElementById('newObName').focus(); return; }

    const needsAddr = type === 'socks5' || type === 'http';
    if (needsAddr && !addr) { document.getElementById('newObAddr').focus(); return; }

    if (pendingOutbounds.some(ob => ob.name === name)) {
        alert('Outbound "' + name + '" уже существует');
        return;
    }

    pendingOutbounds.push({ name, type, addr, username, password });
    renderAll();

    document.getElementById('newObName').value = '';
    document.getElementById('newObAddr').value = '';
    document.getElementById('newObUsername').value = '';
    document.getElementById('newObPassword').value = '';
    document.getElementById('newObName').focus();
}

function removeOutbound(idx) {
    pendingOutbounds.splice(idx, 1);
    renderAll();
}

// ===== RENDER =====
function renderAll() {
    renderCards();
    renderHiddenInputs();
    renderChips();
    checkProxyWarning();
    if (document.getElementById('yamlPreview').style.display !== 'none') {
        updatePreview();
    }
}

function renderCards() {
    const wrap = document.getElementById('obCards');
    const empty = document.getElementById('emptyState');

    if (pendingOutbounds.length === 0) {
        wrap.innerHTML = '';
        empty.style.display = '';
        return;
    }
    empty.style.display = 'none';

    wrap.innerHTML = pendingOutbounds.map((ob, idx) => {
        const m = TYPE_META[ob.type] || { icon: '?', label: ob.type, cls: '' };
        const detail = ob.addr ? ob.addr : (ob.type === 'direct' ? 'прямое соединение' : ob.type === 'block' ? 'блокировка трафика' : '');
        return `<div class="ob-card">
            <span class="ob-card-icon">${m.icon}</span>
            <div class="ob-card-info">
                <div class="ob-card-name">${escHtml(ob.name)}</div>
                <div class="ob-card-detail">
                    <span class="ob-type-badge ${m.cls}">${m.label}</span>
                    ${detail ? `<span style="margin-left:4px">${escHtml(detail)}</span>` : ''}
                </div>
            </div>
            <button type="button" class="ob-card-del" onclick="removeOutbound(${idx})" title="Удалить">✕</button>
        </div>`;
    }).join('');
}

function renderHiddenInputs() {
    document.getElementById('obHiddenInputs').innerHTML = pendingOutbounds.map(ob => `
        <input type="hidden" name="outbound_name"     value="${escHtml(ob.name)}">
        <input type="hidden" name="outbound_type"     value="${escHtml(ob.type)}">
        <input type="hidden" name="outbound_addr"     value="${escHtml(ob.addr || '')}">
        <input type="hidden" name="outbound_username" value="${escHtml(ob.username || '')}">
        <input type="hidden" name="outbound_password" value="${escHtml(ob.password || '')}">
    `).join('');
}

function renderChips() {
    const wrap = document.getElementById('aclChipsWrap');
    const chips = document.getElementById('aclObChips');

    if (pendingOutbounds.length === 0) {
        wrap.style.display = 'none';
        return;
    }
    wrap.style.display = '';

    chips.innerHTML = pendingOutbounds.map(ob => {
        const m = TYPE_META[ob.type] || { cls: '', icon: '' };
        return `<button type="button" class="acl-ob-chip ${m.cls}" onclick="insertObName('${escHtml(ob.name)}')"
            title="Вставить '${escHtml(ob.name)}(' в правило">${m.icon} ${escHtml(ob.name)}</button>`;
    }).join('');
}

// ===== ACL HELPERS =====
function insertAcl(rule) {
    const ta = document.getElementById('aclRulesEditor');
    const lines = ta.value ? ta.value.split('\n') : [];
    if (!lines.includes(rule)) {
        lines.push(rule);
        ta.value = lines.join('\n');
    }
    checkProxyWarning();
}

function insertObName(name) {
    const ta = document.getElementById('aclRulesEditor');
    const pos = ta.selectionStart;
    const val = ta.value;
    const insert = name + '(';
    ta.value = val.slice(0, pos) + insert + val.slice(pos);
    ta.selectionStart = ta.selectionEnd = pos + insert.length;
    ta.focus();
}

function checkProxyWarning() {
    const hasProxy = pendingOutbounds.some(ob => ob.type === 'socks5' || ob.type === 'http');
    const aclRules = document.getElementById('aclRulesEditor').value.trim();
    const warn = document.getElementById('noAclWarning');
    if (hasProxy && !aclRules) {
        const proxyName = pendingOutbounds.find(ob => ob.type === 'socks5' || ob.type === 'http')?.name || 'my-proxy';
        document.getElementById('aclExampleRule').textContent = proxyName + '(all)';
        warn.style.display = '';
    } else {
        warn.style.display = 'none';
    }
}

// ===== YAML PREVIEW =====
function togglePreview() {
    const pre = document.getElementById('yamlPreview');
    const arrow = document.getElementById('previewArrow');
    const visible = pre.style.display !== 'none';
    if (visible) {
        pre.style.display = 'none';
        arrow.textContent = '▶';
    } else {
        updatePreview();
        pre.style.display = '';
        arrow.textContent = '▼';
    }
}

function updatePreview() {
    const aclRules = document.getElementById('aclRulesEditor').value
        .split('\n').map(r => r.trim()).filter(Boolean);

    let yaml = '';
    if (pendingOutbounds.length > 0) {
        yaml += 'outbounds:\n';
        pendingOutbounds.forEach(ob => {
            yaml += `  - name: ${ob.name}\n    type: ${ob.type}\n`;
            if (ob.type === 'socks5' || ob.type === 'http') {
                yaml += `    ${ob.type}:\n      addr: ${ob.addr}\n`;
                if (ob.username) yaml += `      username: ${ob.username}\n`;
                if (ob.password) yaml += `      password: ****\n`;
            }
        });
        yaml += '\n';
    }
    if (aclRules.length > 0) {
        yaml += 'acl:\n  inline:\n';
        aclRules.forEach(r => { yaml += `    - ${r}\n`; });
    }

    document.getElementById('yamlPreview').textContent = yaml || '(нет outbounds и ACL-правил — используются настройки по умолчанию)';
}

// ===== SAVE & APPLY =====
async function saveAndApply() {
    const btn = document.getElementById('btnApply');
    const origHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '⏳ Применяется...';

    const form = document.getElementById('outboundsForm');
    const formData = new FormData(form);

    try {
        await fetch(form.action, {
            method: 'POST',
            body: new URLSearchParams(formData),
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            redirect: 'manual',
        });

        const applyRes = await fetch('/api/nodes/' + NODE_ID + '/update-config', { method: 'POST' });
        const applyData = await applyRes.json();

        if (applyData.success) {
            btn.innerHTML = '✅ Применено';
            setTimeout(() => { btn.innerHTML = origHtml; btn.disabled = false; }, 3000);
        } else {
            alert('Ошибка: ' + (applyData.error || 'Неизвестная ошибка'));
            btn.innerHTML = origHtml;
            btn.disabled = false;
        }
    } catch (err) {
        alert('Ошибка: ' + err.message);
        btn.innerHTML = origHtml;
        btn.disabled = false;
    }
}

// ===== UTILS =====
function escHtml(str) {
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

// ===== INIT =====
onTypeChange(document.getElementById('newObType').value);
renderAll();
document.getElementById('aclRulesEditor').addEventListener('input', () => {
    checkProxyWarning();
    if (document.getElementById('yamlPreview').style.display !== 'none') updatePreview();
});
</script>
